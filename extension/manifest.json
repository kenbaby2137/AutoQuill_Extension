{
  "manifest_version": 3,
  "name": "AutoQuill",
  "version": "1.4.0",
  "description": "Human-like typing automation for X.com with persona-based typing patterns, realistic delays, and typo simulation",

  "permissions": [
    "tabs",
    "webNavigation",
    "scripting",
    "storage",
    "sidePanel",
    "bookmarks",
    "debugger"
  ],

  "side_panel": {
    "default_path": "popup/popup.html"
  },

  "commands": {
    "start-typing": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Start typing current block"
    },
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Toggle AutoQuill panel"
    },
    "next-block": {
      "suggested_key": {
        "default": "Ctrl+Shift+X"
      },
      "description": "Switch to next block"
    }
  },

  "host_permissions": [
    "http://127.0.0.1:8899/*",
    "http://localhost:8899/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "file:///*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AutoQuill",
    "default_popup": "popup/popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}